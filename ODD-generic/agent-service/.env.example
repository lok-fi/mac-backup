# Gemini API key for ADK (either name works).
GOOGLE_API_KEY=AIzaSyBUh0n4zBjKJZ7qz34zxZ7o0LqyQGZ3jBA
# GEMINI_API_KEY=your-gemini-api-key

# Optional: pin the model (defaults to gemini-flash-latest).
