# Google Gemini — Backend AI assistant
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_SCORECARD_MODEL=gemini-3.1-flash-lite

# SMTP — Nodemailer (Gmail app password)
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here

# App configuration
SETUP_KEY=your_one_time_setup_key_here
BASE_URL=https://your-catalyst-app.development.catalystserverless.in
